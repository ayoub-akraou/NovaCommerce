PORT=3000
NODE_ENV=development

# PostgreSQL connection URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/novacommerce?schema=public"

# Minimum 16 characters
JWT_SECRET="change-this-dev-secret-please"

# Comma-separated origins (example: "http://localhost:3000,http://localhost:3001")
CORS_ORIGIN="http://localhost:3000"
